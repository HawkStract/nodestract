import * from nio
import * from nfs

function run_stress_test() {
    print("=== STARTING STRESS TEST ===")
    let total_score = 0

    // 1. Loop 10k
    print(">>> Stress 1: 10,000 Iterations")
    let i = 0
    while i < 10000 { 
        i = i + 1 
    }
    if i == 10000 { 
        total_score = total_score + 5 
        print("[PASS] 1. 10k Loop") 
    } else { 
        print("Fail 1") 
    }

    // 2. Loop 2k
    print(">>> Stress 2: 2,000 Iterations")
    let k = 0
    while k < 2000 { 
        k = k + 1 
    }
    if k == 2000 { 
        total_score = total_score + 5 
        print("[PASS] 2. 2k Loop") 
    } else { 
        print("Fail 2") 
    }

    // 3. String Concatenation 2k
    print(">>> Stress 3: 2,000 String Concats")
    let s = ""
    let j = 0
    while j < 2000 { 
        s = s + "." 
        j = j + 1 
    }
    if j == 2000 { 
        total_score = total_score + 5 
        print("[PASS] 3. 2k Strings") 
    } else { 
        print("Fail 3") 
    }

    // 4. Nested 50x50
    print(">>> Stress 4: Nested Loops (50x50)")
    let outer = 0
    let counts = 0
    while outer < 50 {
        let inner = 0
        while inner < 50 { 
            counts = counts + 1 
            inner = inner + 1 
        }
        outer = outer + 1
    }
    if counts == 2500 { 
        total_score = total_score + 5 
        print("[PASS] 4. Nested") 
    } else { 
        print("Fail 4") 
    }

    // 5. FS Stress Write
    print(">>> Stress 5: FS Write Cycles")
    let fs_i = 0
    while fs_i < 50 {
        write("test.txt", "DATA")
        fs_i = fs_i + 1
    }
    if fs_i == 50 { 
        total_score = total_score + 25 
        print("[PASS] 5. 50 FS Writes") 
    } else { 
        print("Fail FS Write") 
    }

    // 6. FS Stress Read
    print(">>> Stress 6: FS Read Cycles")
    let fs_j = 0
    while fs_j < 50 {
        let d = read("test.txt")
        fs_j = fs_j + 1
    }
    if fs_j == 50 { 
        total_score = total_score + 25 
        print("[PASS] 6. 50 FS Reads") 
    } else { 
        print("Fail FS Read") 
    }

    print("------------------------------------------")
    print("TOTAL SCORE:", total_score, "/ 70")
}

run_stress_test()