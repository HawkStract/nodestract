module LogicTest;
use IO {}

func run_logic_test() {
    IO.print("=== AVVIO LOGIC TEST (Target: 100/100) ===");
    stract score = 0;
    stract a = 10;
    stract b = 20;

    // 1-5: Basic Logic (25pt)
    if a < b { score = score + 5; IO.print("[PASS] 1. If <"); } else { IO.print("Fail 1"); }
    if a == 10 { score = score + 5; IO.print("[PASS] 2. If =="); } else { IO.print("Fail 2"); }
    if a != 20 { score = score + 5; IO.print("[PASS] 3. If !="); } else { IO.print("Fail 3"); }
    if a >= 10 { score = score + 5; IO.print("[PASS] 4. If >="); } else { IO.print("Fail 4"); }
    if b <= 20 { score = score + 5; IO.print("[PASS] 5. If <="); } else { IO.print("Fail 5"); }

    // 6-9: Boolean Ops (20pt)
    if a == 10 && b == 20 { score = score + 5; IO.print("[PASS] 6. AND (&&)"); } else { IO.print("Fail 6"); }
    if a == 99 || b == 20 { score = score + 5; IO.print("[PASS] 7. OR (||)"); } else { IO.print("Fail 7"); }
    if (a == 10 && b == 20) || a == 99 { score = score + 5; IO.print("[PASS] 8. Complex AND/OR"); } else { IO.print("Fail 8"); }
    if a == 99 && b == 99 || a == 10 { score = score + 5; IO.print("[PASS] 9. Precedenza"); } else { IO.print("Fail 9"); }
    
    // 10: Else Branch (5pt)
    if a == 20 { IO.print("Fail 10"); } else { score = score + 5; IO.print("[PASS] 10. Else Branch"); }

    // 11-12: Nested & Scope (10pt)
    stract nested = 0;
    if a == 10 { if b == 20 { nested = 1; } }
    if nested == 1 { score = score + 5; IO.print("[PASS] 11. Nested If"); } else { IO.print("Fail 11"); }

    stract scope_val = 1;
    if 1 == 1 { stract scope_val = 2; }
    if scope_val == 1 { score = score + 5; IO.print("[PASS] 12. Scope Isolation"); } else { IO.print("Fail 12"); }

    // 13-15: Loops (15pt)
    stract i = 0;
    while i < 10 { i = i + 1; }
    if i == 10 { score = score + 5; IO.print("[PASS] 13. While Loop"); } else { IO.print("Fail 13"); }

    stract k = 0;
    for x 0 10 { k = k + 1; }
    if k == 10 { score = score + 5; IO.print("[PASS] 14. For Loop"); } else { IO.print("Fail 14"); }

    stract loop_scope = 0;
    for x 0 5 { stract internal = x; loop_scope = internal; }
    if loop_scope == 4 { score = score + 5; IO.print("[PASS] 15. Loop Logic"); } else { IO.print("Fail 15"); }
    
    // 16-19: Advanced Logic (20pt)
    stract count = 0;
    for x 0 5 { for y 0 2 { count = count + 1; } }
    if count == 10 { score = score + 5; IO.print("[PASS] 16. Nested Loops"); } else { IO.print("Fail 16"); }

    stract j = 0;
    while j < 100 {
        if j == 5 { j = 100; } else { j = j + 1; }
    }
    if j == 100 { score = score + 5; IO.print("[PASS] 17. Manual Break"); } else { IO.print("Fail 17"); }

    if "A" == "A" { score = score + 5; IO.print("[PASS] 18. String Eq"); } else { IO.print("Fail 18"); }
    if "A" != "B" { score = score + 5; IO.print("[PASS] 19. String Neq"); } else { IO.print("Fail 19"); }

    // 20: Float Logic (5pt)
    if 1.5 > 1.0 { score = score + 5; IO.print("[PASS] 20. Float Comparison"); } else { IO.print("Fail 20"); }

    IO.print("------------------------------------------");
    IO.print("PUNTEGGIO TOTALE LOGICA:", score, "/ 100");
}