module MathTest;
use IO {}

func run_math_test() {
    IO.print("=== AVVIO MATH TEST v0.8.0 (40 Tests) ===");
    stract score = 0;

    // --- BASE (2.5pt each) ---
    // 1
    if 10 + 5 == 15 { score += 2.5; IO.print("[OK] 01. Int Sum"); } 
    else { IO.print("[FAIL] 01"); }
    // 2
    if 10 - 5 == 5 { score += 2.5; IO.print("[OK] 02. Int Sub"); } 
    else { IO.print("[FAIL] 02"); }
    // 3
    if 10 * 2 == 20 { score += 2.5; IO.print("[OK] 03. Int Mul"); } 
    else { IO.print("[FAIL] 03"); }
    // 4
    if 20 / 2 == 10 { score += 2.5; IO.print("[OK] 04. Int Div"); } 
    else { IO.print("[FAIL] 04"); }
    // 5
    if 10 + 5 * 2 == 20 { score += 2.5; IO.print("[OK] 05. Precedenza"); } 
    else { IO.print("[FAIL] 05"); }
    // 6
    if 2.5 + 2.5 == 5.0 { score += 2.5; IO.print("[OK] 06. Float Sum"); } 
    else { IO.print("[FAIL] 06"); }
    // 7
    if 5.0 - 2.0 == 3.0 { score += 2.5; IO.print("[OK] 07. Float Sub"); } 
    else { IO.print("[FAIL] 07"); }
    // 8
    if 10 + 2.5 == 12.5 { score += 2.5; IO.print("[OK] 08. Int+Float"); } 
    else { IO.print("[FAIL] 08"); }
    // 9
    if 10.5 - 5 == 5.5 { score += 2.5; IO.print("[OK] 09. Float-Int"); } 
    else { IO.print("[FAIL] 09"); }
    // 10
    if 10.0 / 2.0 == 5.0 { score += 2.5; IO.print("[OK] 10. Float Div"); } 
    else { IO.print("[FAIL] 10"); }
    // 11
    if 0 - 10 == -10 { score += 2.5; IO.print("[OK] 11. Negative"); } 
    else { IO.print("[FAIL] 11"); }
    // 12
    if -5 + 10 == 5 { score += 2.5; IO.print("[OK] 12. Neg Sum"); } 
    else { IO.print("[FAIL] 12"); }
    
    // VAULTS
    vault s = 100;
    lock c = 5;
    stract i = 10;
    // 13
    if s + 1 == 101 { score += 2.5; IO.print("[OK] 13. Vault+Int"); } 
    else { IO.print("[FAIL] 13"); }
    // 14
    if s + c == 105 { score += 2.5; IO.print("[OK] 14. Vault+Lock"); } 
    else { IO.print("[FAIL] 14"); }
    // 15
    if c + i == 15 { score += 2.5; IO.print("[OK] 15. Lock+Stract"); } 
    else { IO.print("[FAIL] 15"); }
    // 16
    if 100 * 0 == 0 { score += 2.5; IO.print("[OK] 16. Zero Mul"); } 
    else { IO.print("[FAIL] 16"); }
    // 17
    if "A" + "B" == "AB" { score += 2.5; IO.print("[OK] 17. Str Concat"); } 
    else { IO.print("[FAIL] 17"); }
    // 18
    if "Ver" + 1 == "Ver1" { score += 2.5; IO.print("[OK] 18. Str+Int"); } 
    else { IO.print("[FAIL] 18"); }
    // 19
    if 10 + "pt" == "10pt" { score += 2.5; IO.print("[OK] 19. Int+Str"); } 
    else { IO.print("[FAIL] 19"); }
    // 20
    if s * 1 == 100 { score += 2.5; IO.print("[OK] 20. Identity"); } 
    else { IO.print("[FAIL] 20"); }

    // --- NEW FEATURES (21-40) ---

    // 21
    stract acc = 10;
    acc += 5; // 15
    if acc == 15 { score += 2.5; IO.print("[OK] 21. +="); } 
    else { IO.print("[FAIL] 21"); }
    // 22
    acc -= 5; // 10
    if acc == 10 { score += 2.5; IO.print("[OK] 22. -="); } 
    else { IO.print("[FAIL] 22"); }
    // 23
    acc *= 2; // 20
    if acc == 20 { score += 2.5; IO.print("[OK] 23. *="); } 
    else { IO.print("[FAIL] 23"); }
    // 24
    acc /= 4; // 5
    if acc == 5 { score += 2.5; IO.print("[OK] 24. /="); } 
    else { IO.print("[FAIL] 24"); }
    // 25
    stract str_acc = "A";
    str_acc += "B";
    if str_acc == "AB" { score += 2.5; IO.print("[OK] 25. Str +="); } 
    else { IO.print("[FAIL] 25"); }
    
    // 26
    stract count = 0;
    count++;
    if count == 1 { score += 2.5; IO.print("[OK] 26. ++"); } 
    else { IO.print("[FAIL] 26"); }
    // 27
    count++; count++; // 3
    if count == 3 { score += 2.5; IO.print("[OK] 27. Double ++"); } 
    else { IO.print("[FAIL] 27"); }
    // 28
    count--;
    if count == 2 { score += 2.5; IO.print("[OK] 28. --"); } 
    else { IO.print("[FAIL] 28"); }
    // 29
    stract loop_acc = 0;
    for x 0 5 { loop_acc++; }
    if loop_acc == 5 { score += 2.5; IO.print("[OK] 29. Loop ++"); } 
    else { IO.print("[FAIL] 29"); }
    // 30
    stract step = 10;
    step--; 
    step += 1;
    if step == 10 { score += 2.5; IO.print("[OK] 30. Mixed Ops"); } 
    else { IO.print("[FAIL] 30"); }

    // 31
    stract t_val = 10 > 5 ? 100 : 0;
    if t_val == 100 { score += 2.5; IO.print("[OK] 31. Ternary True"); } 
    else { IO.print("[FAIL] 31"); }
    // 32
    stract f_val = 10 < 5 ? 100 : 0;
    if f_val == 0 { score += 2.5; IO.print("[OK] 32. Ternary False"); } 
    else { IO.print("[FAIL] 32"); }
    // 33
    stract status = true ? "OK" : "ERR";
    if status == "OK" { score += 2.5; IO.print("[OK] 33. Ternary Str"); } 
    else { IO.print("[FAIL] 33"); }
    // 34
    stract complex = true ? (false ? 1 : 2) : 3;
    if complex == 2 { score += 2.5; IO.print("[OK] 34. Nested Ternary"); } 
    else { IO.print("[FAIL] 34"); }
    // 35
    stract calc = true ? 5 + 5 : 0;
    if calc == 10 { score += 2.5; IO.print("[OK] 35. Ternary Math"); } 
    else { IO.print("[FAIL] 35"); }

    // 36 (Error Resilience)
    IO.print("--- Test Errori (Non devono crashare) ---");
    // 10 / 0 deve ritornare Null (falsy)
    if !(10 / 0) { score += 2.5; IO.print("[OK] 36. DivZero Int"); } 
    else { IO.print("[FAIL] 36"); }
    // 37
    if !(5.0 / 0.0) { score += 2.5; IO.print("[OK] 37. DivZero Float"); } 
    else { IO.print("[FAIL] 37"); }
    // 38
    if !("A" - 5) { score += 2.5; IO.print("[OK] 38. Type Error"); } 
    else { IO.print("[FAIL] 38"); }
    // 39
    if !("Test" * "Test") { score += 2.5; IO.print("[OK] 39. String Mul"); } 
    else { IO.print("[FAIL] 39"); }
    // 40
    // FIX: Rinominato 'safe' in 'safe_result' per evitare conflitto con keyword
    stract safe_result = (10 / 0) ? "Danger" : "Safe";
    if safe_result == "Safe" { score += 2.5; IO.print("[OK] 40. Safe Ternary"); } 
    else { IO.print("[FAIL] 40"); }

    IO.print("------------------------------------------");
    IO.print("PUNTEGGIO TOTALE MATEMATICA:", score, "/ 100");
}