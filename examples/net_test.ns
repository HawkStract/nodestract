module NetTest;
use IO {}
use Sys {}
use FS { "./net_data" }

use Net { "https://jsonplaceholder.typicode.com", "https://www.google.com/robots.txt" }

func run_net_test() {
    IO.print("=== AVVIO NET TEST v0.9.3 (Final Polish) ===");
    stract score = 0;

    // --- 1. GET Request (10pt) ---
    stract url_get = "https://jsonplaceholder.typicode.com/todos/1";
    stract response = Net.get(url_get);
    if response { score += 10; IO.print("[PASS] 01. GET Request OK"); } 
    else { IO.print("[FAIL] 01. Connection Failed"); }

    // --- 2. Content Check (10pt) ---
    if response { score += 10; IO.print("[PASS] 02. Content Valid"); } 
    else { IO.print("[FAIL] 02. No Content"); }

    // --- 3. POST Request (10pt) ---
    // Questo JSON è valido, dovrebbe funzionare ora con il nuovo User-Agent
    stract payload = "{ \"title\": \"foo\", \"body\": \"bar\", \"userId\": 1 }";
    stract post_resp = Net.post("https://jsonplaceholder.typicode.com/posts", payload);
    
    if post_resp { score += 10; IO.print("[PASS] 03. POST Success (201 Created)"); } 
    else { IO.print("[FAIL] 03. POST Failed"); }

    // --- 4. Domain Security (10pt) ---
    stract blocked = Net.get("https://facebook.com");
    if !blocked { score += 10; IO.print("[PASS] 04. Domain Security Block"); } 
    else { IO.print("[FAIL] 04. Security Breach!"); }

    // --- 5. Protocol Security (10pt) ---
    stract protocol = Net.get("http://jsonplaceholder.typicode.com/todos/1");
    if !protocol { score += 10; IO.print("[PASS] 05. Protocol Security (HTTP Blocked)"); } 
    else { IO.print("[FAIL] 05. Protocol Bypass!"); }

    // --- 6. Path-Level Security (10pt) ---
    stract path_check = Net.get("https://www.google.com/");
    if !path_check { score += 10; IO.print("[PASS] 06. Path Restriction OK"); } 
    else { IO.print("[FAIL] 06. Path Restriction Failed"); }

    // --- 7. HTTP 404 Handling (10pt) ---
    stract not_found = Net.get("https://jsonplaceholder.typicode.com/posts/99999999");
    if !not_found { score += 10; IO.print("[PASS] 07. HTTP 404 Handled"); } 
    else { IO.print("[FAIL] 07. 404 Error Logic"); }

    // --- 8. Query Parameters (10pt) ---
    stract query = Net.get("https://jsonplaceholder.typicode.com/comments?postId=1");
    if query { score += 10; IO.print("[PASS] 08. Query Params Allowed"); } 
    else { IO.print("[FAIL] 08. Query Params Blocked"); }

    // --- 9. Integration: Net -> FS (10pt) ---
    stract fpath = "./net_data/api_data.nso"; 
    if response {
        if FS.write(fpath, response) {
            stract disk_data = FS.read(fpath);
            if disk_data { score += 10; IO.print("[PASS] 09. Download & Save (Net->FS)"); } 
            else { IO.print("[FAIL] 09. Readback Failed"); }
        } else { IO.print("[FAIL] 09. Write Failed"); }
    } else { IO.print("[FAIL] 09. Prerequisite Failed"); }

    // --- 10. Integration: Vault -> Net (10pt) ---
    vault token = "SECRET_TOKEN_ABC";
    
    // FIX CRITICO: Costruiamo un JSON valido manuale!
    // Prima inviavamo "SECRET...", ora inviamo { "token": "SECRET..." }
    stract json_body = "{ \"token\": \"" + token + "\" }";
    
    stract v_post = Net.post("https://jsonplaceholder.typicode.com/posts", json_body);
    if v_post {
        score += 10;
        IO.print("[PASS] 10. Vault Transmission OK");
    } else {
        IO.print("[FAIL] 10. Vault Transmission Failed");
    }

    IO.print("------------------------------------------");
    IO.print("PUNTEGGIO NET:", score, "/ 100");
}