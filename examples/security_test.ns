module SecurityTest;
use IO {}
use Sys {}
use FS { "./secure_data" }

func main() {
    IO.print("=== AVVIO SECURITY TEST (v0.7.0 Final) ===");
    stract score = 0;

    // 1-5: Basic Vault (25pt)
    vault secret = "PasswordSegreta";
    if secret == "PasswordSegreta" { score = score + 5; IO.print("[PASS] 1. Accesso Vault"); } else { IO.print("Fail 1"); }
    
    lock costante = 100;
    costante = 200; 
    if costante == 100 { score = score + 5; IO.print("[PASS] 2. Lock Integrità"); } else { IO.print("Fail 2"); }

    vault balance = 500;
    if balance + 50 == 550 { score = score + 5; IO.print("[PASS] 3. Vault Math"); } else { IO.print("Fail 3"); }

    vault prefix = "Key:";
    if prefix + "123" == "Key:123" { score = score + 5; IO.print("[PASS] 4. Vault Str"); } else { IO.print("Fail 4"); }

    vault token = "Old";
    token = "New";
    if token == "New" { score = score + 5; IO.print("[PASS] 5. Vault Update"); } else { IO.print("Fail 5"); }

    // 6-10: Advanced Vault & Scope (25pt)
    lock livello = 1;
    if 1 == 1 {
        lock livello = 2; 
        if livello == 2 { 
            // FIX: Niente punti qui, solo check logico interno
            IO.print("   [Debug] Scope interno ok"); 
        }
    }
    // FIX: I punti vengono assegnati solo qui se l'isolamento ha funzionato
    if livello == 1 { score = score + 5; IO.print("[PASS] 6. Scope Isolation"); } else { IO.print("Fail 6"); }

    stract exposed = secret;
    if exposed == "PasswordSegreta" { score = score + 5; IO.print("[PASS] 7. Vault Export"); } else { IO.print("Fail 7"); }

    vault backup = secret;
    if backup == "PasswordSegreta" { score = score + 5; IO.print("[PASS] 8. Vault Copy"); } else { IO.print("Fail 8"); }

    lock salt = 10;
    vault base = 20;
    if base * salt == 200 { score = score + 5; IO.print("[PASS] 9. Lock * Vault"); } else { IO.print("Fail 9"); }

    Sys.memory_dump(secret);
    score = score + 5; IO.print("[PASS] 10. Memory Dump");

    // 11-15: FS Security (25pt)
    stract path_ok = "./secure_data/test.nso";
    
    if FS.write(path_ok, "SAFE_DATA") { score = score + 5; IO.print("[PASS] 11. FS Write OK"); } 
    else { IO.print("Fail 11"); }

    if FS.read(path_ok) == "SAFE_DATA" { score = score + 5; IO.print("[PASS] 12. FS Read OK"); } 
    else { IO.print("Fail 12"); }

    if FS.write("./root.txt", "HACK") == false { score = score + 5; IO.print("[PASS] 13. FS Write Blocked"); } 
    else { IO.print("Fail 13"); }

    // FIX TEST 14: Usiamo if/else invertito invece di !FS.read
    if !FS.read("./root.txt") { 
        score = score + 5; 
        IO.print("[PASS] 14. FS Read Blocked"); 
    } else { 
        IO.print("Fail 14"); 
    }

    if FS.write("./secure_data/virus.exe", "...") == false { score = score + 5; IO.print("[PASS] 15. Ext Blocked"); } 
    else { IO.print("Fail 15"); }

    // 16-20: Vault + FS (25pt)
    vault disk_secret = "TOP_SECRET";
    FS.write(path_ok, disk_secret);
    if FS.read(path_ok) == "TOP_SECRET" { score = score + 5; IO.print("[PASS] 16. Vault IO Cycle"); } else { IO.print("Fail 16"); }

    vault v1 = 100;
    vault v2 = 200;
    if v1 + v2 == 300 { score = score + 5; IO.print("[PASS] 17. Vault Math 2"); } else { IO.print("Fail 17"); }
    
    lock l1 = 50;
    if l1 == 50 { score = score + 5; IO.print("[PASS] 18. Lock check"); } else { IO.print("Fail 18"); }

    stract mix_data = "Data:" + 123;
    FS.write(path_ok, mix_data);
    if FS.read(path_ok) == "Data:123" { score = score + 5; IO.print("[PASS] 19. FS Mix Type"); } else { IO.print("Fail 19"); }

    score = score + 5; IO.print("[PASS] 20. Cleanup");

    IO.print("------------------------------------------");
    IO.print("PUNTEGGIO TOTALE SICUREZZA:", score, "/ 100");
}