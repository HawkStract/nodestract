importa italiano da translate
importa * da nio
importa * da nfs

crea path = "temp_7.json"
crea array = [10, 20, 30]
scrivi(path, array)

crea letto = leggi(path)
crea del_ok = elimina(path)

se (letto[0] == 10 && letto[1] == 20 && letto[2] == 30 && del_ok == vero) {
    stampa("Test 7 OK")
} altrimenti {
    stampa("FAIL: Test 7 failed")
}
