importa italiano da translate
importa * da nio
importa * da nfs

crea path = "temp_8.json"
scrivi(path, {"chiave": "valore"})
crea del_ok = elimina(path)
crea letto = leggi(path)

se (del_ok == vero && letto == nullo) {
    stampa("Test 8 superato: OK")
} altrimenti {
    stampa("ERRORE: Test 8 fallito")
}
