importa italiano da translate
importa * da nio

funzione fattoriale(n) {
    se (n <= 1) {
        ritorna 1
    }
    ritorna n * fattoriale(n - 1)
}

crea ris = fattoriale(5)
stampa("Fattoriale di 5:", ris)

se (ris == 120) {
    stampa("Ricorsione su singola funzione (fattoriale): OK")
} altrimenti {
    stampa("ERRORE: fattoriale(5) != 120, era invece", ris)
}
