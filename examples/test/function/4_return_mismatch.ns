importa italiano da translate
importa * da nio

funzione get_nome() {
    ritorna "Luca"
}

crea errore_rilevato = falso
prova {
    crea ris = get_nome() * 3
} cattura (e) {
    errore_rilevato = vero
}

se (errore_rilevato == vero) {
    stampa("Return mismatch handling OK")
} altrimenti {
    stampa("ERRORE: get_nome() * 3 non ha generato eccezione per tipo non numerico")
}
