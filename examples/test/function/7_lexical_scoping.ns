importa italiano da translate
importa * da nio

crea x = 100 // variabile globale

funzione stampante() {
    // stampante dovrebbe accedere solo alla sua x locale o alla globale
    // NON a quella definita in chiamante()
    ritorna x
}

funzione chiamante() {
    crea x = 42 // locale del chiamante
    ritorna stampante()
}

crea ris = chiamante()
stampa("Risultato scoping:", ris)

se (ris == 100) {
    stampa("Scoping lessicale delle variabili: OK")
} altrimenti {
    stampa("ERRORE: Si è verificato uno scoping dinamico, trovato valore", ris)
}
