importa italiano da translate
importa * da nio

crea eseguita = falso

se (vero) {
    funzione nidificata() {
        eseguita = vero
    }
}

// All'atto della dichiarazione sopra, non deve essersi eseguita!
se (eseguita == vero) {
    stampa("ERRORE: la funzione nidificata è stata eseguita al momento della dichiarazione")
} altrimenti {
    // Ora la chiamiamo
    nidificata()
    se (eseguita == vero) {
        stampa("Nested declaration OK")
    } altrimenti {
        stampa("ERRORE: la funzione nidificata non è stata registrata o non è stata eseguita")
    }
}
