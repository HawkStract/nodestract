importa italiano da translate
importa * da nio

se (vero && vero) {
    stampa("true && true OK")
} altrimenti {
    stampa("ERRORE: AND vero/vero ha fallito")
}

se (vero && falso) {
    stampa("ERRORE: AND vero/falso ha fallito")
} altrimenti {
    stampa("true && false OK")
}

se (falso && vero) {
    stampa("ERRORE: AND falso/vero ha fallito")
} altrimenti {
    stampa("false && true OK")
}

se (falso && falso) {
    stampa("ERRORE: AND falso/falso ha fallito")
} altrimenti {
    stampa("false && false OK")
}
