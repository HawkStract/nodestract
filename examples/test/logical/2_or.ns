importa italiano da translate
importa * da nio

se (vero || vero) {
    stampa("true || true OK")
} altrimenti {
    stampa("ERRORE: OR vero/vero ha fallito")
}

se (vero || falso) {
    stampa("true || false OK")
} altrimenti {
    stampa("ERRORE: OR vero/falso ha fallito")
}

se (falso || vero) {
    stampa("false || true OK")
} altrimenti {
    stampa("ERRORE: OR falso/vero ha fallito")
}

se (falso || falso) {
    stampa("ERRORE: OR falso/falso ha fallito")
} altrimenti {
    stampa("false || false OK")
}
