importa italiano da translate
importa * da nio

se ("ciao") { stampa("Valutazione stringa non vuota come vera: OK") } altrimenti { stampa("ERRORE: stringa non vuota valutata come falsa") }
se ("") { stampa("ERRORE: stringa vuota valutata come vera") } altrimenti { stampa("Valutazione stringa vuota come falsa: OK") }

se (1) { stampa("Valutazione numero 1 come vero: OK") } altrimenti { stampa("ERRORE: numero 1 valutato come falso") }
se (0) { stampa("ERRORE: numero 0 valutato come vero") } altrimenti { stampa("Valutazione numero 0 come falso: OK") }

se (nullo) { stampa("ERRORE: valore nullo valutato come vero") } altrimenti { stampa("Valutazione valore nullo come falso: OK") }
