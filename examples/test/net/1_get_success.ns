importa italiano da translate
importa * da nio
importa * da nnet

crea ris = richiedi("http://127.0.0.1:12345/success")
stampa("Risultato GET:", ris)

se (ris == "Hello NodeStract") {
    stampa("Richiesta GET completata: OK")
} altrimenti {
    stampa("ERRORE: la richiesta GET non ha restituito il valore corretto")
}
