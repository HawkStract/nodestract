importa italiano da translate
importa * da nio
importa * da nnet

crea ris = richiedi("http://127.0.0.1:12345/retry")
stampa("Risultato Retry:", ris)

se (ris == "Retry success") {
    stampa("Riprova richiesta GET su errore server: OK")
} altrimenti {
    stampa("ERRORE: la riprova della richiesta GET non ha restituito il valore corretto")
}
