importa italiano da translate
importa * da nio

crea t = vero
crea f = falso

se (t) {
    stampa("Booleano vero: OK")
} altrimenti {
    stampa("ERRORE: il valore vero è stato valutato falso")
}

se (f) {
    stampa("ERRORE: il valore falso è stato valutato vero")
} altrimenti {
    stampa("Booleano falso: OK")
}

crea and_op = t && f
se (and_op) {
    stampa("ERRORE: l'operazione AND ha restituito vero per valori diversi")
} altrimenti {
    stampa("Operazione logica AND: OK")
}

crea or_op = t || f
se (or_op) {
    stampa("Operazione logica OR: OK")
} altrimenti {
    stampa("ERRORE: l'operazione OR ha restituito falso per valori veri")
}

crea not_op = !t
se (not_op) {
    stampa("ERRORE: la negazione logica NOT ha fallito")
} altrimenti {
    stampa("Operazione logica NOT: OK")
}
