importa italiano da translate
importa * da nio

crea str1 = "Ciao"
crea str2 = "Mondo"

// Concatenazione
crea unione = str1 + " " + str2
stampa("Concatenazione:", unione)

// Uguaglianza
se (str1 == "Ciao") {
    stampa("Uguaglianza stringhe OK")
} altrimenti {
    stampa("FAIL: str1 == Ciao")
}

se (str1 != str2) {
    stampa("Disuguaglianza stringhe OK")
} altrimenti {
    stampa("FAIL: str1 != str2")
}
