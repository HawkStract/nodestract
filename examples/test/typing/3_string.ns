importa italiano da translate
importa * da nio

crea str1 = "Ciao"
crea str2 = "Mondo"

// Concatenazione
crea unione = str1 + " " + str2
stampa("Concatenazione:", unione)

// Uguaglianza
se (str1 == "Ciao") {
    stampa("Uguaglianza stringhe: OK")
} altrimenti {
    stampa("ERRORE: le stringhe non risultano uguali")
}

se (str1 != str2) {
    stampa("Disuguaglianza stringhe: OK")
} altrimenti {
    stampa("ERRORE: le due stringhe diverse risultano uguali")
}
