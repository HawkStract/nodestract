importa italiano da translate
importa * da nio

crea x = nullo

se (x == nullo) {
    stampa("Confronto nullo: OK")
} altrimenti {
    stampa("ERRORE: il valore x non risulta nullo")
}

crea y = 10
se (y != nullo) {
    stampa("Confronto non nullo: OK")
} altrimenti {
    stampa("ERRORE: il valore y risulta nullo")
}
