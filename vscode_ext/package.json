{
  "name": "nodestract-lang",
  "displayName": "Node Stract Support",
  "description": "Language support and icons for Node Stract (.ns)",
  "version": "0.6.0",
  "engines": {
    "vscode": "^1.60.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "nodestract",
        "aliases": ["Node Stract", "ns"],
        "extensions": [".ns"],
        "configuration": "./language-configuration.json"
      }
    ],
    "iconThemes": [
      {
        "id": "nodestract-icon-theme",
        "label": "Node Stract Icons",
        "path": "./icons.json"
      }
    ]
  }
}